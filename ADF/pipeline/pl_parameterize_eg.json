					"items": {
						"value": "@activity('Get Metadata1').output.childItems",
						"type": "Expression"
					},
					"condition": {
						"value": "@contains(item().name,'.json')",
						"type": "Expression"
					}
				}
			}
		],
		"folder": {
			"name": "test_project"
